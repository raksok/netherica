<!doctype html>
<html lang="th">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Netherica Report</title>
  <style>
    @font-face {
      font-family: 'Sarabun';
      src: url('data:font/ttf;base64,{{ thai_font_base64 }}') format('truetype');
      font-weight: normal;
      font-style: normal;
    }

    :root {
      --border: #444;
      --text: #111;
      --muted: #555;
      --header-bg: #f4f4f4;
    }

    * { box-sizing: border-box; }

    body {
      font-family: 'Sarabun', sans-serif;
      color: var(--text);
      margin: 0;
      padding: 0;
      font-size: 10.5px;
      line-height: 1.25;
      background: #fff;
    }

    .report-shell {
      padding: 8mm;
    }

    .report-meta {
      border: 1px solid var(--border);
      padding: 6px 8px;
      margin-bottom: 6px;
      font-size: 10.5px;
    }

    .meta-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2px 10px;
      margin-top: 4px;
    }

    .product-page {
      border: 1px solid var(--border);
      padding: 8px;
      margin-bottom: 12px;
      break-inside: avoid;
      page-break-inside: avoid;
    }

    .product-id {
      font-size: 18px;
      font-weight: 700;
      letter-spacing: 0.2px;
      margin: 0;
    }

    .product-name {
      margin: 1px 0 6px;
      font-size: 12px;
      font-weight: 600;
    }

    .page-heading {
      margin-bottom: 6px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
    }

    th, td {
      border: 1px solid var(--border);
      padding: 3px 4px;
      vertical-align: middle;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    th {
      background: var(--header-bg);
      font-weight: 700;
      text-align: left;
    }

    .header-subunit {
      display: block;
      font-size: 9px;
      line-height: 1.1;
    }

    .num {
      text-align: right;
      white-space: nowrap;
    }

    .summary-lines {
      margin-top: 6px;
      border-top: 1px dashed var(--border);
      padding-top: 5px;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 3px 12px;
      font-size: 10.5px;
    }

    .summary-item {
      display: flex;
      justify-content: space-between;
      gap: 12px;
    }

    .summary-item strong { font-weight: 700; }

    .report-footer {
      margin-top: 8px;
      font-size: 10px;
      color: var(--muted);
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      border-top: 1px solid var(--border);
      padding-top: 5px;
    }

    .small { font-size: 11px; color: var(--muted); }

    @page {
      size: A4 landscape;
      margin: 0;
    }

    @media print {
      .report-shell {
        padding: 8mm;
      }

      body {
        font-size: 10px;
      }

      th, td {
        padding: 3px;
      }

      .product-page {
        page-break-after: always;
      }

      .product-page:last-child {
        page-break-after: auto;
      }

      tr, td, th {
        break-inside: avoid;
        page-break-inside: avoid;
      }
    }
  </style>
</head>
<body>
  <div class="report-shell">
    {% for row in rows %}
    <section class="product-page">
      <header class="report-meta page-heading">
        <div><strong>Netherica Inventory Usage Report</strong> (A4 landscape)</div>
        <div class="meta-grid">
          <div><strong>Processed filename:</strong> {{ source_filename }}</div>
          <div><strong>Generated at (BE, local):</strong> {{ generated_at_be_local }}</div>
          <div><strong>Transaction period (BE):</strong> {{ period_start_be }} - {{ period_end_be }}</div>
          <div><strong>Calendar basis:</strong> Gregorian internal / Buddhist Era display</div>
        </div>
      </header>

      <p class="product-id">{{ row.product_id }}</p>
      <p class="product-name">{{ row.product_display_name }}</p>

      <table>
        <thead>
          <tr>
            <th style="width: 22%;">Consume Department Code</th>
            <th style="width: 22%;">Product name</th>
            <th class="num" style="width: 9%;">ยอดยกมา</th>
            <th class="num" style="width: 9%;">ขอยืม</th>
            <th class="num" style="width: 12%;">เบิก<br><span class="header-subunit">({{ row.subunit }})</span></th>
            <th class="num" style="width: 8%;">จ่าย</th>
            <th style="width: 9%;">unit</th>
            <th class="num" style="width: 9%;">ยอดยกไป<br><span class="header-subunit">({{ row.subunit }})</span></th>
          </tr>
        </thead>
        <tbody>
          {% for dept in row.department_rows %}
          <tr>
            <td>{{ dept.consume_department_code }}</td>
            <td>{{ dept.product_name }}</td>
            <td class="num">{{ dept.opening_leftover }}</td>
            <td class="num">{{ dept.borrowed }}</td>
            <td class="num">{{ dept.dispensed }}</td>
            <td class="num">{{ dept.issued }}</td>
            <td>{{ dept.unit }}</td>
            <td class="num">{{ dept.closing_leftover }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>

        <div class="summary-lines">
          <div class="summary-item"><span>ยอดยกมา (รวม)</span><strong>{{ row.opening_leftover }}</strong></div>
          <div class="summary-item"><span>ขอยืม</span><strong>&nbsp;</strong></div>
          <div class="summary-item"><span>เบิก (รวม)</span><strong>{{ row.total_subunits_used }}</strong></div>
          <div class="summary-item"><span>จ่าย (รวม)</span><strong>{{ row.total_issued }}</strong></div>
          <div class="summary-item"><span>Whole Units Output</span><strong>{{ row.whole_units_output }}</strong></div>
          <div class="summary-item"><span>Closing Leftover</span><strong>{{ row.closing_leftover }}</strong></div>
        </div>

      <footer class="report-footer">
        <span><strong>Generated at (BE):</strong> {{ generated_at_be_local }}</span>
        <span><strong>Report version:</strong> {{ report_version }}</span>
        <span><strong>File hash:</strong> {{ file_hash }}</span>
      </footer>
    </section>
    {% endfor %}

  </div>
</body>
</html>
